# Global options & Snippets
{
    acme_dns cloudflare {env.CLOUDFLARE_API_TOKEN}
}

(cloudflare_tls) {
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }
}

# 1. Drop direct IP scans
:80, :443 {
    @ip {
        header_regexp host Host ^[0-9.]+$
    }
    abort @ip
}

# 2. Apex Redirect (aleqsys.com -> www.aleqsys.com)
aleqsys.com {
    redir https://www.aleqsys.com{uri} permanent
}

# 3. Marketing Site (www.)
www.aleqsys.com {
    import cloudflare_tls
    encode zstd gzip

    root * /var/www/aleqsys.com

    # Static/Media for the App
    handle_path /static/* {
        root * /var/www/aleqsys.com/aleqsys_app/staticfiles/
        file_server
    }
    handle_path /media/* {
        root * /var/www/aleqsys.com/aleqsys_app/media/
        file_server
    }

    reverse_proxy unix//run/aleqsys-prod/uvicorn.sock
}

# 4. Main Application (app.)
app.aleqsys.com {
    import cloudflare_tls
    encode zstd gzip

    # Static/Media for the App
    handle_path /static/* {
        root * /var/www/aleqsys.com/aleqsys_app/staticfiles/
        file_server
    }
    handle_path /media/* {
        root * /var/www/aleqsys.com/aleqsys_app/media/
        file_server
    }

    # The App Backend
    reverse_proxy unix//run/aleqsys-prod/uvicorn.sock
}

# 5. Automation Tool (n8n.)
n8n.aleqsys.com {
    import cloudflare_tls
    reverse_proxy localhost:5678 {
        flush_interval -1
    }
}

# 6. LLM Observability (phoenix.)
phoenix.aleqsys.com {
    import cloudflare_tls
    basicauth {
        admin $2a$14$2MrzgsnSBPWHAw.0prWHb.3/uq4JCiSOD6wwLTId4U5A5WolLGiqm
    }
    reverse_proxy localhost:6006
}
phoenix.aleqsys.com {
    import cloudflare_tls
    reverse_proxy localhost:6006
}

# 7. Staging Environment (app)
app-staging.aleqsys.com {
    import cloudflare_tls

    root * /var/www/staging.aleqsys.com

    # Static/Media for the App
    handle_path /static/* {
        root * /var/www/staging.aleqsys.com/aleqsys_app/staticfiles/
        file_server
    }
    handle_path /media/* {
        root * /var/www/staging.aleqsys.com/aleqsys_app/media/
        file_server
    }

    reverse_proxy 127.0.0.1:8001

    log {
        output file /var/log/caddy/staging_access.log
    }
}

# 8. Staging Environment (www)
www-staging.aleqsys.com {
    import cloudflare_tls

    root * /var/www/staging.aleqsys.com

    # Static/Media for the App
    handle_path /static/* {
        root * /var/www/staging.aleqsys.com/aleqsys_app/staticfiles/
        file_server
    }
    handle_path /media/* {
        root * /var/www/staging.aleqsys.com/aleqsys_app/media/
        file_server
    }

    reverse_proxy 127.0.0.1:8001

    log {
        output file /var/log/caddy/staging_access.log
    }
}
