{
  email admin@aleqsys.com
  auto_https disable_redirects
}

# Redirect apex to www
aleqsys.com {
  redir https://www.aleqsys.com{uri}
}

# Marketing site
www.aleqsys.com {
  root * /var/www/aleqsys.com/marketing
  file_server
  encode gzip
}

# Main application
app.aleqsys.com {
  reverse_proxy unix//run/gunicorn/gunicorn.sock
  encode gzip
}

# n8n automation
n8n.aleqsys.com {
  reverse_proxy localhost:5678
}

