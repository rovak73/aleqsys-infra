# Domain Configuration
BASE_DOMAIN=aleqsys.com
WWW_DOMAIN=www.aleqsys.com
APP_DOMAIN=app.aleqsys.com
STAGING_DOMAIN=staging.aleqsys.com
N8N_DOMAIN=n8n.aleqsys.com

# Cross-Repository Updates Required:
# 1. Update Django ALLOWED_HOSTS to use BASE_DOMAIN
# 2. Update Svelte/Vite config to use VITE_BASE_DOMAIN
# 3. Update frontend/.env.example with VITE_BASE_DOMAIN

# Django Settings
DEBUG=false
SECRET_KEY=your_django_secret_key_here
DJANGO_SETTINGS_MODULE=aleqsys_app.settings.production

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_USER=your_db_user_here
DATABASE_PASSWORD=your_db_password_here
DATABASE_NAME=your_db_name_here

# PostgreSQL Docker Container
POSTGRES_USER=db_admin
POSTGRES_PASSWORD=your_secure_postgres_password_here
POSTGRES_DB=aleqsys_com

# Redis
REDIS_URL=redis://localhost:6379/0

# Cloudflare
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ZONE_ID=your_zone_id_here

# n8n
N8N_USER=your_n8n_username_here
N8N_PASSWORD=your_n8n_password_here
N8N_GREETING_WEBHOOK_URL=your_n8n_greeting_webhook_url_here
N8N_WEBHOOK_SECRET=your_n8n_webhook_secret_here
N8N_PUSH_SECRET=your_n8n_push_secret_here

# Docker / Infrastructure
DISK_THRESHOLD=90
SLACK_WEBHOOK_URL=your_slack_webhook_url_here_optional

# External APIs (Optional - placeholders for keys found in app)
GOOGLE_API_KEY=your_google_api_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_HOST=https://cloud.langfuse.com
RESEND_API_KEY=your_resend_api_key_here
MAILGUN_API_KEY=your_mailgun_api_key_here
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key_here
LEMONSQUEEZY_STORE_ID=your_store_id_here
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret_here
